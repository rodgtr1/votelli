<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Votelli</string>
    <key>CFBundleDisplayName</key>
    <string>Votelli</string>
    <key>CFBundleIdentifier</key>
    <string>media.travis.votelli</string>
    <key>CFBundleExecutable</key>
    <string>Votelli</string>
    <!-- Names Resources/Votelli.icns. CFBundleIconFile (not CFBundleIconName) is
         the right key here: this bundle is hand-assembled and drops a plain .icns
         into Resources, with no compiled asset catalog (Assets.car) for
         CFBundleIconName to resolve against. -->
    <key>CFBundleIconFile</key>
    <string>Votelli</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.5.0</string>
    <key>CFBundleVersion</key>
    <string>5</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>Votelli listens while you hold the push-to-talk key and types what you say.</string>
    <key>NSHumanReadableCopyright</key>
    <string>Votelli</string>

    <!-- Sparkle updater. Pull-only: the background scheduler is off, so the app
         never checks for updates on its own and Sparkle's first-run "check
         automatically?" prompt never appears. Updater.swift also sets this in
         code (belt and suspenders) and supplies the appcast URL from there, which
         is why there is no SUFeedURL key here. -->
    <key>SUEnableAutomaticChecks</key>
    <false/>

    <!-- Production Ed25519 key that verifies Sparkle updates. The matching private
         half signs each appcast entry and lives ONLY in the release machine's login
         Keychain (service "https://sparkle-project.org", account "ed25519"), backed
         up outside this repo.

         Changing this value invalidates every update for every existing install:
         Sparkle refuses any appcast entry not signed by the private key that pairs
         with whatever public key the INSTALLED app shipped. There is no revocation
         and no server. So this is frozen for the life of the product — losing the
         private key means never being able to ship a trusted update again, and a
         mismatch here silently breaks updates for everyone. Treat it like the
         Developer ID identity. -->
    <key>SUPublicEDKey</key>
    <string>W5Jn7EJ/28kZ5Ml4wblCLvlr9N3Ih5pX2fs5SznPA98=</string>
</dict>
</plist>
